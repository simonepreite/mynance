# mynance — environment template.
# Copy to .env (gitignored) and fill in real values for local dev.
# NEVER commit a real .env. Compose reads the root .env at boot and hard-fails
# on any missing required variable.

# Domain (Traefik / deploy). Local dev uses localhost.
DOMAIN=localhost

# Frontend origin used by the backend (links, CORS). Vite dev server default.
FRONTEND_HOST=http://localhost:5173

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="mynance"
STACK_NAME=mynance

# --- Backend ---
# CORS is locked to these origins + FRONTEND_HOST (never a wildcard).
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:5173,https://localhost,https://localhost:5173"
# Generate a real one: `python -c "import secrets;print(secrets.token_urlsafe(32))"`
SECRET_KEY=changethis
# First superuser seeded by the prestart step (app/initial_data.py).
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# --- Email (verification link + password reset) ---
# DEV: leave SMTP_HOST blank → emails are NOT sent; the verification / reset
#   link is logged to the backend console (look for "EMAIL (dev, not sent)").
# PROD: any SMTP relay works (no provider lock-in). Recommended free tier: Brevo
#   (smtp-relay.brevo.com, 300 mail/day). Set SMTP_USER = your Brevo login and
#   SMTP_PASSWORD = the Brevo *SMTP key*, and EMAILS_FROM_EMAIL to a verified
#   sender. Links are built from FRONTEND_HOST.
SMTP_HOST=
# SMTP_HOST=smtp-relay.brevo.com
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME=mynance
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24

# --- Postgres ---
# LOCAL DEV: these point at the compose `db` service (compose overrides SERVER).
# DEPLOY (Neon): set POSTGRES_SERVER to your Neon host, POSTGRES_USER/PASSWORD/DB
#   to the Neon credentials. Neon requires TLS — append `?sslmode=require` to the
#   connection (set via SQLALCHEMY_DATABASE_URI override or PGSSLMODE=require).
#   Never commit the Neon connection string; keep it in the deployed env only.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

# Optional error monitoring (free-tier Sentry). Leave blank to disable.
SENTRY_DSN=

# Container image names (deploy)
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
